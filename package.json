{
  "name": "openblogagent",
  "version": "0.1.0",
  "private": true,
  "description": "OpenBlogAgent monorepo foundations",
  "license": "MIT",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "pnpm -r --filter ./packages/* --filter ./apps/* run build",
    "clean": "pnpm -r run clean",
    "dev": "pnpm --filter @openblog/server dev",
    "lint": "eslint . --ext .ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter ./packages/* --filter ./apps/* run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "@types/node": "^22.5.4",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.0.5"
  }
}
